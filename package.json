{
  "name": "gigaclaw",
  "version": "1.8.1",
  "type": "module",
  "description": "GigaClaw — Gignaati's autonomous AI agent platform. Build, deploy, and run AI agents 24/7 with a two-layer architecture: Next.js Event Handler + Docker Agent. India-first, edge-native AI.",
  "bin": {
    "gigaclaw": "./bin/cli.js"
  },
  "main": "api/index.js",
  "exports": {
    "./api": {
      "import": "./api/index.js",
      "default": "./api/index.js"
    },
    "./config": {
      "import": "./config/index.js",
      "default": "./config/index.js"
    },
    "./instrumentation": {
      "import": "./config/instrumentation.js",
      "default": "./config/instrumentation.js"
    },
    "./auth": {
      "import": "./lib/auth/index.js",
      "default": "./lib/auth/index.js"
    },
    "./auth/actions": {
      "import": "./lib/auth/actions.js",
      "default": "./lib/auth/actions.js"
    },
    "./chat/api": {
      "import": "./lib/chat/api.js",
      "default": "./lib/chat/api.js"
    },
    "./db": {
      "import": "./lib/db/index.js",
      "default": "./lib/db/index.js"
    },
    "./chat": {
      "import": "./lib/chat/components/index.js",
      "default": "./lib/chat/components/index.js"
    },
    "./chat/actions": {
      "import": "./lib/chat/actions.js",
      "default": "./lib/chat/actions.js"
    },
    "./code": {
      "import": "./lib/code/index.js",
      "default": "./lib/code/index.js"
    },
    "./code/actions": {
      "import": "./lib/code/actions.js",
      "default": "./lib/code/actions.js"
    },
    "./code/ws-proxy": {
      "import": "./lib/code/ws-proxy.js",
      "default": "./lib/code/ws-proxy.js"
    },
    "./middleware": {
      "import": "./lib/auth/middleware.js",
      "default": "./lib/auth/middleware.js"
    },
    "./trust-ledger/actions": {
      "import": "./lib/chat/trust-ledger-actions.js",
      "default": "./lib/chat/trust-ledger-actions.js"
    },
    "./rag": {
      "import": "./lib/rag/index.js",
      "default": "./lib/rag/index.js"
    },
    "./rag/chunker": {
      "import": "./lib/rag/chunker.js",
      "default": "./lib/rag/chunker.js"
    },
    "./rag/embeddings": {
      "import": "./lib/rag/embeddings.js",
      "default": "./lib/rag/embeddings.js"
    },
    "./rag/vector-store": {
      "import": "./lib/rag/vector-store.js",
      "default": "./lib/rag/vector-store.js"
    },
    "./rag/hybrid-search": {
      "import": "./lib/rag/hybrid-search.js",
      "default": "./lib/rag/hybrid-search.js"
    },
    "./rag/watcher": {
      "import": "./lib/rag/watcher.js",
      "default": "./lib/rag/watcher.js"
    },
    "./connectors": {
      "import": "./lib/connectors/index.js",
      "default": "./lib/connectors/index.js"
    },
    "./connectors/filesystem": {
      "import": "./lib/connectors/filesystem.js",
      "default": "./lib/connectors/filesystem.js"
    },
    "./brand": {
      "import": "./lib/brand.js",
      "default": "./lib/brand.js"
    },
    "./package.json": "./package.json",
    "./knowledge-base/actions": {
      "import": "./lib/chat/knowledge-base-actions.js",
      "default": "./lib/chat/knowledge-base-actions.js"
    },
    "./share-actions": {
      "import": "./lib/chat/share-actions.js",
      "default": "./lib/chat/share-actions.js"
    },
    "./share-dialog": {
      "import": "./lib/chat/components/share-dialog.jsx",
      "default": "./lib/chat/components/share-dialog.jsx"
    }
  },
  "files": [
    "bin/",
    "lib/",
    "api/",
    "config/",
    "setup/",
    "templates/",
    "drizzle/"
  ],
  "scripts": {
    "build": "esbuild lib/chat/components/*.jsx lib/chat/components/**/*.jsx --outdir=lib/chat/components --format=esm --jsx=automatic --outbase=lib/chat/components && esbuild lib/code/*.jsx --outdir=lib/code --format=esm --jsx=automatic",
    "prepublishOnly": "npm run build",
    "local": "bash bin/local.sh",
    "postinstall": "node -e \"import('./bin/postinstall.js').catch(()=>{})\"",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "test": "echo \"No tests yet\" && exit 0",
    "test:tty": "node scripts/test-tty-regression.mjs",
    "test:full": "node scripts/test-full.mjs"
  },
  "keywords": [
    "ai",
    "agent",
    "autonomous",
    "gignaati",
    "gigaclaw",
    "telegram",
    "bot",
    "india",
    "edge-ai",
    "nextjs"
  ],
  "author": "Gignaati <support@gignaati.com>",
  "license": "MIT",
  "homepage": "https://www.gignaati.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/gignaati/gigaclaw.git"
  },
  "bugs": {
    "url": "https://github.com/gignaati/gigaclaw/issues"
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.0",
    "@clack/prompts": "^0.10.0",
    "@grammyjs/parse-mode": "^2.2.0",
    "@langchain/anthropic": "^1.3.17",
    "@langchain/core": "^1.1.24",
    "@langchain/google-genai": "^2.1.18",
    "@langchain/langgraph": "^1.1.4",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
    "@langchain/openai": "^1.2.7",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "ai": "^5.0.0",
    "bcrypt-ts": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.3.0",
    "clsx": "^2.0.0",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.44.0",
    "grammy": "^1.39.3",
    "lucide-react": "^0.400.0",
    "node-cron": "^3.0.3",
    "open": "^10.0.0",
    "streamdown": "^2.2.0",
    "tailwind-merge": "^3.0.0",
    "uuid": "^9.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "next": ">=15.5.12 <17",
    "next-auth": ">=5.0.0-beta.30",
    "next-themes": ">=0.4.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "next-auth": {
      "optional": false
    }
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.27.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
