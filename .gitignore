# Credentials - NEVER commit these

.env
.env.local
*.pem
*.key

.claude/*

# Pi system prompt (generated at runtime from SOUL.md)
.pi/SYSTEM.md

# Skills dependencies (installed at runtime in Docker for correct arch)
skills/*/node_modules/

# Database
data/

# Node
node_modules/

# Next.js
.next/
out/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log

# Temporary files
tmp/
temp/
.tmp/

# Compiled JSX output (generated by `npm run build`)
# These are tracked in git so that GitHub-based installs (github:gignaati/gigabot)
# work without requiring esbuild at install time. Run `npm run build` after
# editing any .jsx file and commit the updated .js output.
